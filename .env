# --- App ---
APP_NAME=Secure Chat API
APP_DESCRIPTION=An API for secure chat applications
APP_VERSION=1.0.0

DEBUG=true
PORT=8000
ENV=dev

SECRET_KEY=supersecret

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chat_auth
DB_USER=chat_user
DB_PASSWORD=chat_pass

# --- RP ---
RP_ID=localhost
RP_NAME=Encrypted P2P Chat
RP_ORIGIN=http://localhost:5173
WEBAUTHN_CHALLENGE_TTL_SECONDS=600
WEBAUTHN_CHALLENGE_BYTES=32
REDIS_URL=redis://localhost:6379

USERNAME_MIN_LENGTH=1
USERNAME_MAX_LENGTH=30
DEVICE_NAME_MAX_LENGTH=50

SESSION_TTL_SECONDS=86400
SESSION_COOKIE_NAME="chat_session"
SESSION_TOKEN_BYTES=32